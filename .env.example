# Copy to .env and adjust. Never commit the real .env.

# --- Local data root override (CI/cloud set this to a scratch or mounted dir) ---
# THREAT_DETECTION_DATA_ROOT=/abs/path/to/data-root

# --- MLflow via DagsHub (hosted tracking server) ---
# Replace <user>/<repo> with your DagsHub repo (often same as your GitHub name).
MLFLOW_TRACKING_URI=https://dagshub.com/arpitDhiman2000/ML-Pipeline.mlflow
MLFLOW_TRACKING_USERNAME=arpitDhiman2000
MLFLOW_TRACKING_PASSWORD=<your-dagshub-token>   # paste into .env, NOT here
#
# For a pure LOCAL file store instead (no server), comment the three lines above
# and use:
# MLFLOW_TRACKING_URI=file:./mlruns

# --- AWS (Sprint 5+, real free-tier account) ---
# AWS_REGION=ap-south-1
# AWS_PROFILE=threat-detection
# S3_BUCKET=threat-detection-<your-unique-suffix>
# ECR_REPOSITORY=threat-detection
